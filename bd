            'users' => 0,
            'attachments' => 0,
            'likes' => 0,
            'subscribes' => 0,
            'views' => 0,
            'files' => 0,
            'imported_at' => null,
            'is_imported' => false
        );

        $forums = $this->get('wpforo_forums');
        if ($forums && isset($forums['forums'])) {
            $stats['forums'] = count($forums['forums']);
            $stats['imported_at'] = isset($forums['imported_at']) ? $forums['imported_at'] : null;
            $stats['is_imported'] = true;
        }

        $topics = $this->get('wpforo_topics');
        if ($topics && isset($topics['topics'])) {
            $stats['topics'] = count($topics['topics']);
        }

        $posts = $this->get('wpforo_posts');
        if ($posts && isset($posts['posts'])) {
            $stats['posts'] = count($posts['posts']);
        }

        $users = $this->get('wpforo_users');
        if ($users && isset($users['users'])) {
            $stats['users'] = count($users['users']);
        }

        $attachments = $this->get('wpforo_attachments');
        if ($attachments && isset($attachments['attachments'])) {
            $stats['attachments'] = count($attachments['attachments']);
        }

        $likes = $this->get('wpforo_likes');
        if ($likes && isset($likes['likes'])) {
            $stats['likes'] = count($likes['likes']);
        }

        $subscribes = $this->get('wpforo_subscribes');
        if ($subscribes && isset($subscribes['subscribes'])) {
            $stats['subscribes'] = count($subscribes['subscribes']);
        }

        $views = $this->get('wpforo_views');
        if ($views && isset($views['views'])) {
            $stats['views'] = count($views['views']);
        }

        $filesList = $this->get('wpforo_files_list');
        if ($filesList && isset($filesList['files'])) {
            $stats['files'] = count($filesList['files']);
        }

        return $stats;
    }

    /**
     * Очистить все импортированные данные wpForo
     */
    public function clearWpForoImport() {
        $files = array(
            'wpforo_forums',
            'wpforo_topics',
            'wpforo_posts',
            'wpforo_users',
            'wpforo_attachments',
            'wpforo_likes',
            'wpforo_subscribes',
            'wpforo_views',
            'wpforo_settings',
            'wpforo_files_list'
        );

        foreach ($files as $file) {
            $emptyData = array(
                substr($file, 7) => array(), // убираем префикс "wpforo_"
                'imported_at' => null
            );
            $this->save($file, $emptyData);
        }

        return array('success' => true, 'message' => 'Импортированные данные wpForo очищены');
    }
}
