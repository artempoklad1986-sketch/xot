    /**
     * Импорт полного экспорта wpForo из JSON файла
     * @param string $jsonFilePath - путь к файлу экспорта
     * @return array - результат импорта
     */
    public function importWpForoFromJson($jsonFilePath) {
        if (!file_exists($jsonFilePath)) {
            return array(
                'success' => false,
                'error' => 'Файл не найден: ' . $jsonFilePath
            );
        }

        $jsonContent = @file_get_contents($jsonFilePath);
        if ($jsonContent === false) {
            return array(
                'success' => false,
                'error' => 'Не удалось прочитать файл'
            );
        }

        $exportData = json_decode($jsonContent, true);
        if (json_last_error() !== JSON_ERROR_NONE) {
            return array(
                'success' => false,
                'error' => 'Ошибка JSON: ' . json_last_error_msg()
            );
        }

        if (!isset($exportData['data'])) {
            return array(
                'success' => false,
                'error' => 'Неверная структура файла экспорта'
            );
        }

        $stats = array(
            'forums' => 0,
            'topics' => 0,
            'posts' => 0,
            'users' => 0,
            'attachments' => 0,
            'likes' => 0,
            'subscribes' => 0,
            'views' => 0,
            'files' => 0
        );

        $timestamp = date('Y-m-d H:i:s');

        // 1. Импорт форумов (разделов)
        if (isset($exportData['data']['forums']) && !empty($exportData['data']['forums'])) {
            $forumsData = array(
                'forums' => $exportData['data']['forums'],
                'imported_at' => $timestamp,
                'source' => 'wpForo export',
                'export_date' => isset($exportData['export_date']) ? $exportData['export_date'] : null,
                'site_url' => isset($exportData['site_url']) ? $exportData['site_url'] : null
            );
            $this->save('wpforo_forums', $forumsData);
            $stats['forums'] = count($exportData['data']['forums']);
        }

        // 2. Импорт тем
        if (isset($exportData['data']['topics']) && !empty($exportData['data']['topics'])) {
            $topicsData = array(
                'topics' => $exportData['data']['topics'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_topics', $topicsData);
            $stats['topics'] = count($exportData['data']['topics']);
        }

        // 3. Импорт постов
        if (isset($exportData['data']['posts']) && !empty($exportData['data']['posts'])) {
            $postsData = array(
                'posts' => $exportData['data']['posts'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_posts', $postsData);
            $stats['posts'] = count($exportData['data']['posts']);
        }

        // 4. Импорт пользователей
        if (isset($exportData['data']['users']) && !empty($exportData['data']['users'])) {
            $usersData = array(
                'users' => $exportData['data']['users'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_users', $usersData);
            $stats['users'] = count($exportData['data']['users']);
        }

        // 5. Импорт вложений
        if (isset($exportData['data']['attachments']) && !empty($exportData['data']['attachments'])) {
            $attachmentsData = array(
                'attachments' => $exportData['data']['attachments'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_attachments', $attachmentsData);
            $stats['attachments'] = count($exportData['data']['attachments']);
        }

        // 6. Импорт лайков
        if (isset($exportData['data']['likes']) && !empty($exportData['data']['likes'])) {
            $likesData = array(
                'likes' => $exportData['data']['likes'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_likes', $likesData);
            $stats['likes'] = count($exportData['data']['likes']);
        }

        // 7. Импорт подписок
        if (isset($exportData['data']['subscribes']) && !empty($exportData['data']['subscribes'])) {
            $subscribesData = array(
                'subscribes' => $exportData['data']['subscribes'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_subscribes', $subscribesData);
            $stats['subscribes'] = count($exportData['data']['subscribes']);
        }

        // 8. Импорт просмотров
        if (isset($exportData['data']['views']) && !empty($exportData['data']['views'])) {
            $viewsData = array(
                'views' => $exportData['data']['views'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_views', $viewsData);
            $stats['views'] = count($exportData['data']['views']);
        }

        // 9. Импорт настроек
        if (isset($exportData['data']['settings']) && !empty($exportData['data']['settings'])) {
            $settingsData = array(
                'settings' => $exportData['data']['settings'],
                'imported_at' => $timestamp
            );
            $this->save('wpforo_settings', $settingsData);
        }

        // 10. Импорт списка файлов (для последующей загрузки)
        if (isset($exportData['data']['files']) && !empty($exportData['data']['files'])) {
            $totalSize = 0;
            foreach ($exportData['data']['files'] as $file) {
                if (isset($file['size'])) {
                    $totalSize += $file['size'];
                }
            }

            $filesData = array(
                'files' => $exportData['data']['files'],
                'imported_at' => $timestamp,
                'total_size' => $totalSize,
                'total_size_mb' => round($totalSize / 1024 / 1024, 2)
            );
            $this->save('wpforo_files_list', $filesData);
            $stats['files'] = count($exportData['data']['files']);
        }

        return array(
            'success' => true,
            'stats' => $stats,
            'imported_at' => $timestamp
        );
    }

