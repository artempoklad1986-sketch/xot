    public function getNextId($filename, $arrayKey) {
        $data = $this->get($filename);
        if (!$data || !isset($data[$arrayKey]) || empty($data[$arrayKey])) {
            return 1;
        }

        $maxId = 0;
        foreach ($data[$arrayKey] as $item) {
            if (isset($item['id']) && $item['id'] > $maxId) {
                $maxId = $item['id'];
            }
        }

        return $maxId + 1;
    }

